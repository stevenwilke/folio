{
  "expo": {
    "name": "Ex Libris",
    "slug": "ex-libris",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f0e8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.exlibris.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f5f0e8"
      },
      "package": "com.exlibris.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Ex Libris needs camera access to scan book barcodes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#c0521e",
          "defaultChannel": "default"
        }
      ]
    ],
    "scheme": "exlibris",
    "experiments": {
      "typedRoutes": true
    }
  }
}
